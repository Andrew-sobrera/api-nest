NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orders_db?schema=public

JWT_SECRET=change-me-to-a-strong-secret-key-in-production
JWT_EXPIRES_IN=1d

THROTTLE_TTL=60000
